// Shared build settings for all configurations.
// ROSTR+ GCC iOS app.

// ── Identity ─────────────────────────────────────────────
// PRODUCT_NAME is the binary name + default CFBundleExecutable.
// Apple disallows + [ ] { } ( ) * in CFBundleExecutable, so we
// use the "safe" alphanumeric form. The user-visible name is
// CFBundleDisplayName below — that gets the branded "ROSTR+".
PRODUCT_NAME = RostrPlus
PRODUCT_BUNDLE_IDENTIFIER = io.rosterplus.app
MARKETING_VERSION = 0.1.0
CURRENT_PROJECT_VERSION = 1

// ── Platform ─────────────────────────────────────────────
IPHONEOS_DEPLOYMENT_TARGET = 18.0
SUPPORTED_PLATFORMS = iphoneos iphonesimulator
TARGETED_DEVICE_FAMILY = 1

// ── Swift concurrency ────────────────────────────────────
// Swift 6 strict-concurrency mode — every Sendable violation is an error.
// Matches the guidance in CLAUDE.md and keeps @MainActor boundaries honest.
SWIFT_VERSION = 6.0
SWIFT_STRICT_CONCURRENCY = complete

// ── Code signing ─────────────────────────────────────────
// Entitlements file lets an AI agent toggle capabilities without
// touching the Xcode project. Same declarative pattern as the
// FitTrackApp template mentioned in CLAUDE.md.
CODE_SIGN_ENTITLEMENTS = Config/RostrPlus.entitlements
CODE_SIGN_STYLE = Automatic
DEVELOPMENT_TEAM =

// ── Build ────────────────────────────────────────────────
SWIFT_TREAT_WARNINGS_AS_ERRORS = YES
ENABLE_USER_SCRIPT_SANDBOXING = YES

// ── Info.plist keys (synthesised by Xcode) ──────────────
// These land in the generated Info.plist. Xcode injects each
// INFOPLIST_KEY_* as the matching plist entry, so we don't need
// a hand-maintained plist file. Add new keys here.

// User-visible name on the home screen. Diverges from PRODUCT_NAME
// because CFBundleExecutable can't contain '+' (App Store Connect
// validator rejects it).
INFOPLIST_KEY_CFBundleDisplayName = ROSTR+

// CFBundleIconName is auto-injected by Xcode based on
// ASSETCATALOG_COMPILER_APPICON_NAME (set in project.yml) and the
// presence of an AppIcon set in Assets.xcassets — no manual key here.

// Photo library — PhotosPicker in ProfileEditView (avatar + gallery).
INFOPLIST_KEY_NSPhotoLibraryUsageDescription = ROSTR+ needs photo access to upload your avatar and gallery images.
INFOPLIST_KEY_NSPhotoLibraryAddUsageDescription = ROSTR+ needs permission to save booking receipts to your photo library.

// Camera — not yet used, but ProfileEditView's Change-photo flow
// will reach for it once the native camera sheet lands.
INFOPLIST_KEY_NSCameraUsageDescription = ROSTR+ uses the camera to capture artist profile photos.

// Push — lets UIApplication deliver silent + alert notifications in
// the background. Paired with aps-environment in the entitlements.
INFOPLIST_KEY_UIBackgroundModes = remote-notification
