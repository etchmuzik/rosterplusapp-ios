// Shared build settings for all configurations.
// ROSTR+ GCC iOS app.

// ── Identity ─────────────────────────────────────────────
PRODUCT_NAME = ROSTR+
PRODUCT_BUNDLE_IDENTIFIER = io.rosterplus.app
MARKETING_VERSION = 0.1.0
CURRENT_PROJECT_VERSION = 1

// ── Platform ─────────────────────────────────────────────
IPHONEOS_DEPLOYMENT_TARGET = 17.0
SUPPORTED_PLATFORMS = iphoneos iphonesimulator
TARGETED_DEVICE_FAMILY = 1

// ── Swift concurrency ────────────────────────────────────
// Swift 6 strict-concurrency mode — every Sendable violation is an error.
// Matches the guidance in CLAUDE.md and keeps @MainActor boundaries honest.
SWIFT_VERSION = 6.0
SWIFT_STRICT_CONCURRENCY = complete

// ── Code signing ─────────────────────────────────────────
// Entitlements file lets an AI agent toggle capabilities without
// touching the Xcode project. Same declarative pattern as the
// FitTrackApp template mentioned in CLAUDE.md.
CODE_SIGN_ENTITLEMENTS = Config/RostrPlus.entitlements
CODE_SIGN_STYLE = Automatic
DEVELOPMENT_TEAM =

// ── Build ────────────────────────────────────────────────
SWIFT_TREAT_WARNINGS_AS_ERRORS = YES
ENABLE_USER_SCRIPT_SANDBOXING = YES
