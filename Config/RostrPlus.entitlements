<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- ROSTR+ iOS entitlements.

       AI agents: edit this file to toggle capabilities.
       Each <key>/<value> pair maps to one capability.

       Currently enabled:
         - Sign in with Apple (screens 01 Onboard + 20 SignIn)
         - Push notifications (registered at sign-in; server-side sends
           deferred to v1.1 per plan)
         - Keychain sharing (token persistence across app launches)
  -->

  <key>com.apple.developer.applesignin</key>
  <array>
    <string>Default</string>
  </array>

  <!-- APS environment interpolated from the build config:
       Debug → "development" (APNs sandbox, for iPhone + simulator test builds)
       Release → "production" (APNs production, for TestFlight + App Store)
       The value is set via APS_ENVIRONMENT in Debug.xcconfig / Release.xcconfig. -->
  <key>aps-environment</key>
  <string>$(APS_ENVIRONMENT)</string>

  <key>keychain-access-groups</key>
  <array>
    <string>$(AppIdentifierPrefix)io.rosterplus.app</string>
  </array>

  <!-- Associated Domains — universal links from rosterplus.io into the
       app. The AASA file at https://rosterplus.io/.well-known/apple-app-site-association
       is fetched by iOS on first install (and on updates) to learn which
       paths to intercept. Components map: /bookings/*, /threads/*,
       /contracts/*, /invoices/*, /reviews/*, /artists/*, /epk(s)/*,
       /notifications. webcredentials enables Sign-in-with-Apple +
       password-autofill round-trips with the same domain. -->
  <key>com.apple.developer.associated-domains</key>
  <array>
    <string>applinks:rosterplus.io</string>
    <string>webcredentials:rosterplus.io</string>
  </array>
</dict>
</plist>
