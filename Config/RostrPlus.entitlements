<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- ROSTR+ iOS entitlements.

       AI agents: edit this file to toggle capabilities.
       Each <key>/<value> pair maps to one capability.

       Currently enabled:
         - Sign in with Apple (screens 01 Onboard + 20 SignIn)
         - Push notifications (registered at sign-in; server-side sends
           deferred to v1.1 per plan)
         - Keychain sharing (token persistence across app launches)
  -->

  <key>com.apple.developer.applesignin</key>
  <array>
    <string>Default</string>
  </array>

  <!-- APS environment interpolated from the build config:
       Debug → "development" (APNs sandbox, for iPhone + simulator test builds)
       Release → "production" (APNs production, for TestFlight + App Store)
       The value is set via APS_ENVIRONMENT in Debug.xcconfig / Release.xcconfig. -->
  <key>aps-environment</key>
  <string>$(APS_ENVIRONMENT)</string>

  <key>keychain-access-groups</key>
  <array>
    <string>$(AppIdentifierPrefix)io.rosterplus.app</string>
  </array>
</dict>
</plist>
